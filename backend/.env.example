# FinGuard Backend Environment Configuration

# Database Configuration
# For development (SQLite)
DATABASE_URL=sqlite:///./finguard.db

# For production (PostgreSQL)
# DATABASE_URL=postgresql+psycopg2://username:password@localhost:5432/finguard

# JWT Configuration
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_SECRET_IN_PRODUCTION
JWT_ALGO=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Environment
ENVIRONMENT=development

# Redis Configuration (Optional)
# REDIS_URL=redis://localhost:6379/0

# Celery Configuration (Optional)
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2
